createAmmoGui()
local remote = getShootRemote()
log("remote: " .. (remote and "OK" or "MISSING"))

connection = RunService.Heartbeat:Connect(function()
    pcall(tick_autoshoot)
    pcall(updateAmmoDisplay)
    if tick() - debugTimer > 3 then
        local weaponId = getWeaponIdentifier() or "none"
        local fr = getWeaponFireRate()
        local enemies = 0
        for _, p in ipairs(Players:GetPlayers()) do
            if isEnemy(p) and isAlive(p.Character) then enemies = enemies + 1 end
        end
        log(string.format("shots:%d | fr:%.3f | ammo:%d/%d | id:%s | enemies:%d", shotCount, fr, currentAmmo, magazineSize, tostring(weaponId):sub(1, 20), enemies))
        debugTimer = tick()
    end
end)

espConnection = RunService.Heartbeat:Connect(function() pcall(updateESP) end)
bhopConnection = RunService.Heartbeat:Connect(function() pcall(tick_bhop); pcall(tick_noflash) end)
lightingConnection = RunService.Heartbeat:Connect(function() pcall(tick_lighting) end)

Players.PlayerRemoving:Connect(function(player) 
    removeHighlight(player)
    removeHealthGui(player)
end)

