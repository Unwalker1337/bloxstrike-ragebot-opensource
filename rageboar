local WeaponModule = require(ReplicatedStorage.Components.Weapon)
local RemotesModule = require(ReplicatedStorage.Database.Security.Remotes)
local OriginalReload = WeaponModule.reload

local function hookedReload(self, ...)
    if Toggles.NoReload and Toggles.NoReload.Value then
        if self.IsDestroyed or self.IsReloading or self.IsShooting then return end
        if self.Properties.Rounds == self.Rounds then return end

        local needed = self.Properties.Rounds - self.Rounds
        local toAdd = math.min(needed, self.Capacity)

        self.Rounds = self.Rounds + toAdd
        self.Capacity = self.Capacity - toAdd
        self.IsReloading = false
        self.IsInspecting = false
        self.IsShooting = false
        self.CurrentReloadIdentity = nil
    else
        return OriginalReload(self, ...)
    end
end

if newcclosure then
    WeaponModule.reload = newcclosure(hookedReload)
else
    WeaponModule.reload = hookedReload
end

