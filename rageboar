local function updateESP()
    local seen = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then removeHighlight(player); removeHealthGui(player); continue end
        local theirTeam = player:GetAttribute("Team")
        if not theirTeam or theirTeam == "Spectators" then removeHighlight(player); removeHealthGui(player); continue end
        if Toggles.TeamCheck.Value and theirTeam == getLocalTeam() then removeHighlight(player); removeHealthGui(player); continue end
        
        local char = player.Character
        if not char then removeHighlight(player); removeHealthGui(player); continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then removeHighlight(player); removeHealthGui(player); continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then removeHighlight(player); removeHealthGui(player); continue end
        if not char:IsDescendantOf(Workspace) then removeHighlight(player); removeHealthGui(player); continue end

        seen[player] = true

        if Toggles.ESPEnabled.Value then
            ensureHighlight(char, player)
        else
            removeHighlight(player)
        end

        local showHealth = Toggles.HealthESP.Value or Toggles.HealthBar.Value
        if showHealth then
            local bg = ensureHealthGui(char, player)
            if bg then
                local healthPct = hum.Health / math.max(hum.MaxHealth, 1)
                
                local textLabel = bg:FindFirstChild("HealthText")
                if textLabel then
                    textLabel.Visible = Toggles.HealthESP.Value
                    if Toggles.HealthESP.Value then
                        textLabel.Text = tostring(math.floor(hum.Health))
                    end
                end
                
                local barBg = bg:FindFirstChild("BarBg")
                local barFill = barBg and barBg:FindFirstChild("BarFill")
                if barFill then
                    barBg.Visible = Toggles.HealthBar.Value
                    if Toggles.HealthBar.Value then
                        barFill.Size = UDim2.new(healthPct, 0, 1, 0)
                        if healthPct > 0.5 then
                            barFill.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
                        elseif healthPct > 0.25 then
                            barFill.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
                        else
                            barFill.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                        end
                    end
                end
            end
        else
            removeHealthGui(player)
        end
    end
    
    for player, hl in pairs(highlights) do
        if not seen[player] then pcall(function() hl:Destroy() end); highlights[player] = nil end
    end
    for player, bg in pairs(healthGuis) do
        if not seen[player] then pcall(function() bg:Destroy() end); healthGuis[player] = nil end
    end

    updateWallbangESP()
end

