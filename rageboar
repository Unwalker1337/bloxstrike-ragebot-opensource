local function shootPacket(targetPart, targetPlayer)
    local remote = getShootRemote()
    if not remote then return false end
    
    local identifier, weaponName = getWeaponIdentifier()
    if not identifier then return false end
    
    local camera = Workspace.CurrentCamera
    if not camera then return false end
    local camPos = camera.CFrame.Position
    
    local char = LocalPlayer.Character
    if not char or char:GetAttribute("Dead") then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    
    if GameState.GetState() == "Buy Period" then return false end
    
    if targetPlayer then
        local tChar = targetPlayer.Character
        if not tChar then return false end
        local tHum = tChar:FindFirstChildOfClass("Humanoid")
        if not tHum or tHum.Health <= 0 then return false end
        if not tChar:IsDescendantOf(Workspace) then return false end
    end

    local direction = (targetPart.Position - camPos).Unit
    local hits, hitInst, hitPos = doRaycast(camPos, direction, Options.MaxDistance.Value)

    local isSniper = (weaponName == "SSG 08" or weaponName == "AWP")
    local isScoped = camera.FieldOfView < 70
    local scopeFlag = isSniper and isScoped

    shotSeq = shotSeq + 1
    
    remote:FireServer({
        IsSniperScoped = scopeFlag,
        ShootingHand = "Right",
        Identifier = identifier,
        Seq = shotSeq,
        Bullets = {
            {
                Direction = direction,
                Origin = camPos,
                Hits = hits
            }
        }
    })

    if Toggles.TracersEnabled and Toggles.TracersEnabled.Value then
        local bHitPos = hitPos or (camPos + direction * Options.MaxDistance.Value)
        pcall(function() drawTracer(camPos, bHitPos) end)
    end
    
    deductAmmo(1)
    
    if hitPos then
        local throughWall = #hits > 1
        local damage = calcDamage(hitInst, throughWall)
        if Toggles.ShowHitMarkers and Toggles.ShowHitMarkers.Value then
            pcall(function() showHitNumber(hitPos, damage, classifyHitPart(hitInst) == "Head") end)
        end
        
        local tChar = targetPlayer.Character
        local tHum = tChar and tChar:FindFirstChildOfClass("Humanoid")
        local isKill = false
        if tHum and tHum.Health > 0 then
            if tHum.Health - damage <= 0 then
                isKill = true
            end
        end

        if isKill then
            if Toggles.KillSound and Toggles.KillSound.Value then
                pcall(function() playSound(Options.KillSoundDropdown.Value, Options.KillSoundVolume.Value, Options.KillSoundPitch.Value) end)
            end
        else
            if Toggles.HitSound and Toggles.HitSound.Value then
                pcall(function() playSound(Options.HitSoundDropdown.Value, Options.HitSoundVolume.Value, Options.HitSoundPitch.Value) end)
            end
        end
    end

    return true
end

local function doReload()
    if isReloading then return false end
    local id, weaponName = getWeaponIdentifier()
    if not id then return false end
    local stats = weaponName and WeaponDB[weaponName]
    local magSize = stats and stats.Rounds or magazineSize
    
    isReloading = true
    
    if Toggles.NoReload and Toggles.NoReload.Value then
        currentAmmo = magSize
        updateAmmoDisplay()
        task.delay(0.05, function()
            isReloading = false
        end)
    else
        pcall(function()
            RemotesModule.Inventory.ReloadWeapon.Send({
                Identifier = id,
                Rounds = currentAmmo,
                Capacity = 999
            })
        end)
        
        task.delay(Options.ReloadTime.Value, function()
            currentAmmo = magSize
            updateAmmoDisplay()
            isReloading = false
        end)
    end
    
    return true
end

local function tick_autoshoot()
    if not Toggles.AimbotEnabled.Value then return end
    local now = tick()
    if now < nextShotAllowed then return end
    if isReloading then return end
    
    local fireRate = getWeaponFireRate()
    if currentAmmo <= 0 then
        pcall(doReload)
        nextShotAllowed = now + Options.ReloadTime.Value 
        return
    end
    
    local targetPlayer, targetPart = findBestTarget()
    if not targetPlayer or not targetPart then return end
    
    aimCameraAt(targetPart)
    
    local _, weaponName = getWeaponIdentifier()
    local isSniper = (weaponName == "SSG 08" or weaponName == "AWP")
    
    if Toggles.NoFireDelay.Value and not isSniper then
        local stats = WeaponDB[weaponName]
        if stats then
            local tChar = targetPlayer.Character
            local tHum = tChar and tChar:FindFirstChildOfClass("Humanoid")
            if tHum and tHum.Health > 0 then
                local initialHealth = tHum.Health
                local camera = Workspace.CurrentCamera
                local camPos = camera.CFrame.Position
                
                task.spawn(function()
                    local shotsFired = 0
                    local maxShots = currentAmmo
                    
                    while shotsFired < maxShots do
                        if not Toggles.AimbotEnabled.Value then break end
                        if currentAmmo <= 0 or isReloading then break end
                        
                        local cChar = targetPlayer.Character
                        if not cChar then break end
                        local cHum = cChar:FindFirstChildOfClass("Humanoid")
                        if not cHum or cHum.Health <= 0 then break end
                        
                        local cPart = findVisibleHitbox(camPos, cChar)
                        if not cPart then break end
                        
                        local partName = classifyHitPart(cPart)
                        local baseDmg = stats.Damage[partName] or stats.Damage["Torso"] or 50
                        
                        local direction = (cPart.Position - camPos).Unit
                        local hits, _, _ = doRaycast(camPos, direction, Options.MaxDistance.Value)
                        local throughWall = hits and #hits > 1
                        if throughWall and stats.Wbm > 0 and stats.Wbm < 1 then
                            baseDmg = math.floor(baseDmg * stats.Wbm)
                        end
                        
                        local remainingHealth = initialHealth - (shotsFired * baseDmg)
                        if remainingHealth <= 0 then break end
                        
                        local shotsNeeded = math.ceil(remainingHealth / baseDmg)
                        if shotsFired >= shotsNeeded then break end
                        
                        aimCameraAt(cPart)
                        local ok = shootPacket(cPart, targetPlayer)
                        if ok then
                            shotCount = shotCount + 1
                            shotsFired = shotsFired + 1
                            task.wait(0.1)
                        else
                            break 
                        end
                    end
                end)
                
                nextShotAllowed = tick() + 0.1
                return
            end
        end
    end
    
    local ok = shootPacket(targetPart, targetPlayer)
    if ok then
        nextShotAllowed = now + fireRate
        shotCount = shotCount + 1
    end
end

