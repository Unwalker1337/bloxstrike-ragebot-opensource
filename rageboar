local HITBOX_ORDER = {
    "Head", "HumanoidRootPart", "UpperTorso", "LowerTorso", "Torso",
    "LeftUpperArm", "RightUpperArm", "LeftLowerArm", "RightLowerArm", "LeftHand", "RightHand",
    "LeftArm", "RightArm",
    "LeftUpperLeg", "RightUpperLeg", "LeftLowerLeg", "RightLowerLeg", "LeftFoot", "RightFoot",
    "LeftLeg", "RightLeg"
}

local function isTargetVisible(origin, targetPart)
    if not Toggles.WallCheck.Value then return true end
    local direction = targetPart.Position - origin
    local distance = direction.Magnitude
    if distance > Options.MaxDistance.Value then return false end

    local penValue = getWeaponPen()
    local targetModel = targetPart:FindFirstAncestorOfClass("Model")
    local filter = getBaseFilter()
    local curOrigin = origin
    local remaining = distance

    for _ = 1, 8 do
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        params.CollisionGroup = "Bullet"
        params.FilterDescendantsInstances = filter
        local result = nil
        local rayDir = direction.Unit * remaining
        for _ = 1, 20 do
            local r = Workspace:Raycast(curOrigin, rayDir, params)
            if not r then result = nil; break end
            if not shouldFilterPart(r.Instance) then result = r; break end
            table.insert(filter, r.Instance)
            params.FilterDescendantsInstances = filter
        end
        if not result then return true end
        local hitDist = (result.Position - curOrigin).Magnitude
        remaining = remaining - hitDist
        if targetModel and result.Instance:IsDescendantOf(targetModel) then return true end
        if not Toggles.Wallbang.Value or penValue <= 0 then return false end
        local mat = getPenMaterial(result.Instance)
        local matDepth = getMaterialDepth(mat)
        if matDepth == 0 and hitDist > penValue then return false end
        table.insert(filter, result.Instance)
        curOrigin = result.Position + direction.Unit * 0.1
    end
    return false
end

local function findVisibleHitbox(origin, character)
    local selectedHitboxes = Options.TargetHitboxes.Value
    if not selectedHitboxes then return nil end
    
    for _, partName in ipairs(HITBOX_ORDER) do
        if selectedHitboxes[partName] then
            local part = character:FindFirstChild(partName)
            if part and isTargetVisible(origin, part) then
                return part
            end
        end
    end
    return nil
end

local function findBestTarget()
    local camera = Workspace.CurrentCamera
    if not camera then return nil, nil end
    local camPos = camera.CFrame.Position
    local bestDist = Options.MaxDistance.Value
    local bestPlayer, bestPart = nil, nil

    for _, player in ipairs(Players:GetPlayers()) do
        if not isEnemy(player) then continue end
        local char = player.Character
        if not isAlive(char) then continue end
        
        local aimPart = findVisibleHitbox(camPos, char)
        if aimPart then
            local dist = (camPos - aimPart.Position).Magnitude
            if dist < bestDist then
                bestDist = dist
                bestPlayer = player
                bestPart = aimPart
            end
        end
    end
    return bestPlayer, bestPart
end

local function aimCameraAt(targetPart)
    local camera = Workspace.CurrentCamera
    if not camera or not targetPart then return end
    local camPos = camera.CFrame.Position
    camera.CFrame = CFrame.new(camPos, targetPart.Position)
end

local function isEnemyPart(instance)
    if not instance then return false end
    local model = instance:FindFirstAncestorOfClass("Model")
    if not model then return false end
    local hum = model:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    local player = Players:GetPlayerFromCharacter(model)
    if not player then return false end
    return isEnemy(player), player
end

local function doRaycast(origin, direction, maxDist)
    local penValue = getWeaponPen()
    local filter = getBaseFilter()
    local hits = {}
    local curOrigin = origin
    local remaining = maxDist
    local lastHitInst, lastHitPos = nil, nil

    for i = 1, 8 do
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        params.CollisionGroup = "Bullet"
        params.FilterDescendantsInstances = filter
        local result = nil
        local rayDir = direction.Unit * remaining
        for _ = 1, 20 do
            local r = Workspace:Raycast(curOrigin, rayDir, params)
            if not r then result = nil; break end
            if not shouldFilterPart(r.Instance) then result = r; break end
            table.insert(filter, r.Instance)
            params.FilterDescendantsInstances = filter
        end
        
        if not result then
            break
        end
        
        local hitDist = (result.Position - curOrigin).Magnitude
        remaining = remaining - hitDist
        local mat = getPenMaterial(result.Instance)
        
        local isEnemy, _ = isEnemyPart(result.Instance)
        local isLastHit = false
        
        if isEnemy then 
            isLastHit = true 
        end
        if not Toggles.Wallbang.Value or penValue <= 0 then 
            isLastHit = true 
        end
        local matDepth = getMaterialDepth(mat)
        if matDepth == 0 and hitDist > penValue then 
            isLastHit = true 
        end

        table.insert(hits, { 
            Instance = result.Instance, 
            Position = result.Position, 
            Normal = result.Normal, 
            Material = mat.Name, 
            Distance = (result.Position - origin).Magnitude, 
            Exit = not isLastHit 
        })
        
        lastHitInst = result.Instance
        lastHitPos = result.Position
        
        if isLastHit then break end
        
        table.insert(filter, result.Instance)
        curOrigin = result.Position + direction.Unit * 0.1
    end
    
    if #hits == 0 then
        table.insert(hits, { 
            Instance = Workspace.Terrain, 
            Position = curOrigin + direction.Unit * remaining, 
            Normal = Vector3.new(0, 1, 0), 
            Material = "Grass", 
            Distance = maxDist, 
            Exit = false 
        })
    end
    
    return hits, lastHitInst, lastHitPos
end

-- РљР РђРЎРР’РђРЇ Р¤РЈРќРљР¦РРЇ Р›РЈР§Р•Р™ (TRACERS)
local function drawTracer(from, to)
    local a0 = Instance.new("Attachment")
    a0.WorldPosition = from
    a0.Parent = Workspace.Terrain
    
    local a1 = Instance.new("Attachment")
    a1.WorldPosition = to
    a1.Parent = Workspace.Terrain
    
    local beam = Instance.new("Beam")
    beam.Attachment0 = a0
    beam.Attachment1 = a1
    
    local color = Options.TracerColor.Value
    local thickness = Options.TracerThickness.Value
    local startTrans = Options.TracerTransparency.Value
    
    beam.Color = ColorSequence.new(color)
    beam.Width0 = thickness
    beam.Width1 = thickness * 0.2 
    
    beam.LightEmission = 1
    beam.LightInfluence = 0
    beam.FaceCamera = true
    beam.Parent = Workspace.Terrain
    
    local duration = Options.TracerLifetime.Value
    local startTime = tick()
    
    task.spawn(function()
        while tick() - startTime < duration do
            local t = (tick() - startTime) / duration
            local currentTrans = startTrans + (1 - startTrans) * t
            beam.Transparency = NumberSequence.new({
                NumberSequenceKeypoint.new(0, currentTrans),
                NumberSequenceKeypoint.new(1, currentTrans)
            })
            task.wait()
        end
        
        beam:Destroy()
        a0:Destroy()
        a1:Destroy()
    end)
end

local function classifyHitPart(hitInstance)
    if not hitInstance then return "Torso" end
    local name = hitInstance.Name
    if name == "Head" then return "Head" end
    if name == "UpperTorso" or name == "LowerTorso" or name == "Torso" or name == "HumanoidRootPart" then return "Torso" end
    local armNames = { "LeftArm", "RightArm", "LeftHand", "RightHand", "LeftLowerArm", "RightLowerArm", "LeftUpperArm", "RightUpperArm" }
    for _, n in ipairs(armNames) do if name == n then return "Arms" end end
    local legNames = { "LeftLeg", "RightLeg", "LeftFoot", "RightFoot", "LeftLowerLeg", "RightLowerLeg", "LeftUpperLeg", "RightUpperLeg" }
    for _, n in ipairs(legNames) do if name == n then return "Legs" end end
    return "Torso"
end

local function calcDamage(hitInstance, throughWall)
    local dmgTable = getWeaponDamage()
    if not dmgTable then return 100 end
    local _, weaponName = getWeaponIdentifier()
    local stats = weaponName and WeaponDB[weaponName]
    local wbm = stats and stats.Wbm or 1
    local part = classifyHitPart(hitInstance)
    local baseDmg = dmgTable[part] or dmgTable["Torso"] or 50
    if throughWall and wbm > 0 and wbm < 1 then baseDmg = math.floor(baseDmg * wbm) end
    return baseDmg
end

