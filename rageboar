local function getWeaponIdentifier()
    local attr = LocalPlayer:GetAttribute("CurrentEquipped")
    if not attr then return nil, nil end
    local ok, data = pcall(function() return HttpService:JSONDecode(attr) end)
    if not ok or not data or not data.Identifier then return nil, nil end
    local identifier = data.Identifier
    local weaponName = data.Name
    if not weaponName then
        local underscore = string.find(identifier, "_")
        if underscore then weaponName = string.sub(identifier, 1, underscore - 1) else weaponName = identifier end
    end
    return identifier, weaponName
end

local function getWeaponFireRate()
    local id, weaponName = getWeaponIdentifier()
    if not weaponName then return cachedFireRate end
    local stats = WeaponDB[weaponName]
    if stats then cachedFireRate = stats.FireRate; return stats.FireRate end
    return cachedFireRate
end

local function getWeaponDamage()
    local _, weaponName = getWeaponIdentifier()
    if not weaponName then return nil end
    local stats = WeaponDB[weaponName]
    if stats then return stats.Damage end
    return nil
end

local function getWeaponPen()
    local _, weaponName = getWeaponIdentifier()
    if not weaponName then return 0 end
    local stats = WeaponDB[weaponName]
    local basePen = stats and stats.Pen or 0
    if Toggles.PenPowerEnabled and Toggles.PenPowerEnabled.Value then
        return Options.PenPowerSlider.Value
    end
    return basePen
end

local function syncAmmo()
    local currentId, weaponName = getWeaponIdentifier()
    if not weaponName then return end
    if currentId ~= lastWeaponId then
        lastWeaponId = currentId
        local stats = WeaponDB[weaponName]
        if stats then magazineSize = stats.Rounds; currentAmmo = magazineSize
        else magazineSize = 30; currentAmmo = 30 end
    end
end

local function updateAmmoDisplay()
    local label = getAmmoLabel()
    if not label then return end
    syncAmmo()
    if currentAmmo <= 0 then label.TextColor3 = Color3.fromRGB(255, 60, 60)
    elseif currentAmmo <= magazineSize * 0.25 then label.TextColor3 = Color3.fromRGB(255, 200, 50)
    else label.TextColor3 = Color3.fromRGB(255, 255, 255) end
    label.Text = tostring(currentAmmo) .. " / " .. tostring(magazineSize)
end

local function deductAmmo(count)
    currentAmmo = currentAmmo - (count or 1)
    if currentAmmo < 0 then currentAmmo = 0 end
    updateAmmoDisplay()
end

local function getLocalTeam() return LocalPlayer:GetAttribute("Team") end

local function isEnemy(player)
    if player == LocalPlayer then return false end
    local theirTeam = player:GetAttribute("Team")
    if not theirTeam or theirTeam == "Spectators" then return false end
    if Toggles.TeamCheck.Value and theirTeam == getLocalTeam() then return false end
    return true
end

local function isAlive(character)
    if not character then return false end
    local hum = character:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0
end

