local function getPenMaterial(inst)
    local p = inst.Parent
    if p and p:HasTag("BreakableDoor") then return Enum.Material.Metal end
    return inst.Material
end

local function shouldFilterPart(instance)
    if instance:FindFirstAncestorWhichIsA("Accessory") then return true end
    if instance.Name == "CollisionCapsule" then return true end
    local debris = workspace:FindFirstChild("Debris")
    if debris and instance:IsDescendantOf(debris) then return true end
    local cam = workspace.CurrentCamera
    if cam and instance:IsDescendantOf(cam) then return true end
    local map = workspace:FindFirstChild("Map")
    if map then
        local cameras = map:FindFirstChild("Cameras")
        if cameras and instance:IsDescendantOf(cameras) then return true end
        local barriers = map:FindFirstChild("Barriers")
        if barriers and instance:IsDescendantOf(barriers) then return true end
        local ambience = map:FindFirstChild("Ambience")
        if ambience and instance:IsDescendantOf(ambience) then return true end
        local zones = map:FindFirstChild("Zones")
        if zones then
            local spawns = zones:FindFirstChild("Spawns")
            if spawns and instance:IsDescendantOf(spawns) then return true end
            local sites = zones:FindFirstChild("Sites")
            if sites and instance:IsDescendantOf(sites) then return true end
        end
    end
    return false
end

