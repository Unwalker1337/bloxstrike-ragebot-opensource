local spinAngle = 0
local randomYaw = 0
local lastRandomUpdate = 0

if RemotesModule.Character and RemotesModule.Character.UpdateLookAngle then
    local OriginalSendLook = RemotesModule.Character.UpdateLookAngle.Send
    local function hookedSendLook(...)
        local args = select(1, ...)
        if Toggles.AntiAimEnabled and Toggles.AntiAimEnabled.Value and typeof(args) == "table" and args.HorizontalAngle then
            local yaw = args.HorizontalAngle
            local yawMode = Options.YawMode.Value
            local pitchMode = Options.PitchMode.Value
            
            if yawMode == "Backward (180)" then
                yaw = yaw + math.pi
            elseif yawMode == "Left (90)" then
                yaw = yaw + math.pi / 2
            elseif yawMode == "Right (-90)" then
                yaw = yaw - math.pi / 2
            elseif yawMode == "Spin" then
                spinAngle = (spinAngle + (Options.SpinSpeed.Value * 0.01)) % (2 * math.pi)
                yaw = yaw + spinAngle
            elseif yawMode == "Random" then
                if tick() - lastRandomUpdate > Options.RandomInterval.Value then
                    randomYaw = (math.random() - 0.5) * 2 * math.pi
                    lastRandomUpdate = tick()
                end
                yaw = randomYaw
            end
            
            -- РќРѕСЂРјР°Р»РёР·СѓРµРј СѓРіРѕР» РІ РґРёР°РїР°Р·РѕРЅ [-pi, pi]
            yaw = (yaw + math.pi) % (2 * math.pi) - math.pi
            args.HorizontalAngle = yaw
            
            if pitchMode == "Down (-1)" then
                args.VerticalLook = -1
            elseif pitchMode == "Up (1)" then
                args.VerticalLook = 1
            elseif pitchMode == "Zero (0)" then
                args.VerticalLook = 0
            elseif pitchMode == "Random" then
                args.VerticalLook = (math.random() - 0.5) * 2
            end
        end
        return OriginalSendLook(...)
    end
    RemotesModule.Character.UpdateLookAngle.Send = (newcclosure and newcclosure(hookedSendLook)) or hookedSendLook
end

if RemotesModule.Spectate and RemotesModule.Spectate.UpdateCameraCFrame then
    local OriginalSendCam = RemotesModule.Spectate.UpdateCameraCFrame.Send
    local function hookedSendCam(...)
        local args = select(1, ...)
        if Toggles.AntiSpectator and Toggles.AntiSpectator.Value and typeof(args) == "CFrame" then
            local rotAmount = Options.SpectatorRotation.Value
            local posAmount = Options.SpectatorPosition.Value
            
            local rx = (math.random() - 0.5) * 2 * rotAmount
            local ry = (math.random() - 0.5) * 2 * rotAmount
            local rz = (math.random() - 0.5) * 2 * rotAmount
            
            local px = (math.random() - 0.5) * 2 * posAmount
            local py = (math.random() - 0.5) * 2 * posAmount
            local pz = (math.random() - 0.5) * 2 * posAmount
            
            args = args * CFrame.new(px, py, pz) * CFrame.Angles(rx, ry, rz)
        end
        return OriginalSendCam(...)
    end
    RemotesModule.Spectate.UpdateCameraCFrame.Send = (newcclosure and newcclosure(hookedSendCam)) or hookedSendCam
end

