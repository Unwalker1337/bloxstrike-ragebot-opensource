-- Р¤РЈРќРљР¦РР WALLBANG X-RAY
local function resetWallbangParts()
    for part, origTrans in pairs(wallbangParts) do
        pcall(function() part.LocalTransparencyModifier = origTrans end)
    end
    wallbangParts = {}
end

local function updateWallbangESP()
    if not Toggles.WallbangESP or not Toggles.WallbangESP.Value then
        resetWallbangParts()
        return
    end

    local penValue = getWeaponPen()
    if penValue <= 0 then
        resetWallbangParts()
        return
    end

    local camera = Workspace.CurrentCamera
    if not camera then return end
    local camPos = camera.CFrame.Position
    local currentWalls = {}

    for _, player in ipairs(Players:GetPlayers()) do
        if isEnemy(player) and isAlive(player.Character) then
            local char = player.Character
            local targetPart = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head")
            if targetPart then
                local direction = targetPart.Position - camPos

                local params = RaycastParams.new()
                params.FilterType = Enum.RaycastFilterType.Exclude
                params.FilterDescendantsInstances = { LocalPlayer.Character }

                local result = Workspace:Raycast(camPos, direction, params)
                if result and result.Instance then
                    local hitModel = result.Instance:FindFirstAncestorOfClass("Model")
                    local hitPlayer = hitModel and Players:GetPlayerFromCharacter(hitModel)
                    
                    if hitPlayer ~= player then
                        local mat = getPenMaterial(result.Instance)
                        local matDepth = getMaterialDepth(mat)
                        if matDepth > 0 then
                            currentWalls[result.Instance] = true
                        end
                    end
                end
            end
        end
    end

    for part, origTrans in pairs(wallbangParts) do
        if not currentWalls[part] then
            pcall(function() part.LocalTransparencyModifier = origTrans end)
            wallbangParts[part] = nil
        end
    end

    local targetTransparency = Options.WallbangTransparency.Value
    for part, _ in pairs(currentWalls) do
        if not wallbangParts[part] then
            if part:IsA("BasePart") or part:IsA("MeshPart") then
                wallbangParts[part] = part.LocalTransparencyModifier
            end
        end
        
        if wallbangParts[part] then
